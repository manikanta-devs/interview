# PrepPro Environment Configuration
# ⚠️  TEMPLATE ONLY - DO NOT PUT REAL API KEYS HERE
# Copy this file to .env.local and add your actual API keys
# ⚠️  NEVER commit .env files to git!

# Google Gemini API Key (Get your FREE key at https://makersuite.google.com/app/apikey)
# ⚠️  Replace with YOUR OWN API key - never share this!
VITE_GEMINI_API_KEY=YOUR_GEMINI_API_KEY_HERE

# Application Configuration
VITE_APP_NAME=NexHire
VITE_APP_ENV=development
VITE_APP_VERSION=1.0.0

# ============================================================================
# HOW TO SETUP SAFELY:
# ============================================================================
# 
# For Local Development:
# 1. Copy this file: cp .env.example .env.local
# 2. Get your own API key: https://makersuite.google.com/app/apikey
# 3. Replace YOUR_GEMINI_API_KEY_HERE with your real key
# 4. NEVER commit .env.local to git (it's in .gitignore)
#
# For Production (Vercel):
# 1. Go to https://vercel.com/dashboard
# 2. Select your project
# 3. Settings → Environment Variables
# 4. Add: VITE_GEMINI_API_KEY = [your key]
# 5. Vercel stores it safely - never exposed to public!
#
# ============================================================================

# Application Configuration
VITE_APP_NAME=NexHire
VITE_APP_ENV=development
VITE_APP_VERSION=1.0.0

# ============================================================================
# HOW TO SETUP SAFELY:
# ============================================================================
# 
# For Local Development:
# 1. Copy this file: cp .env.example .env.local
# 2. Get your own API key: https://makersuite.google.com/app/apikey
# 3. Replace YOUR_GEMINI_API_KEY_HERE with your real key
# 4. NEVER commit .env.local to git (it's in .gitignore)
#
# For Production (Vercel):
# 1. Go to https://vercel.com/dashboard
# 2. Select your project
# 3. Settings → Environment Variables
# 4. Add: VITE_GEMINI_API_KEY = [your key]
# 5. Vercel stores it safely - never exposed to public!
#
# ============================================================================


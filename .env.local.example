VITE_GEMINI_API_KEY=AIzaSyBkVfKuiVRW6ZjQest2CgZwB1IQA2GnztA

# ============================================================================
# OPTIONAL: Email Notifications (EmailJS - FREE - 200 emails/month)
# ============================================================================
# If you want to receive quiz results via email:
# 1. Go to: https://www.emailjs.com
# 2. Sign up for free
# 3. Create email service and template
# 4. Get these IDs:
# VITE_EMAILJS_SERVICE_ID=service_xxxxx
# VITE_EMAILJS_TEMPLATE_ID=template_xxxxx
# VITE_EMAILJS_PUBLIC_KEY=your_public_key
# VITE_EMAIL_AUTOMATION_ENABLED=true

# ============================================================================
# OPTIONAL: Cloud Video Storage (Cloudinary - FREE - 25 credits/month)
# ============================================================================
# If you want to store interview videos:
# 1. Go to: https://cloudinary.com/console/dashboard
# 2. Sign up for free
# 3. Get cloud name and API key
# VITE_CLOUDINARY_CLOUD_NAME=your_cloud_name
# VITE_CLOUDINARY_API_KEY=your_api_key

# ============================================================================
# OPTIONAL: Analytics (Plausible - Privacy-first)
# ============================================================================
# If you want basic analytics without personal data collection:
# VITE_PLAUSIBLE_DOMAIN=yourapp.com
# VITE_PLAUSIBLE_API_KEY=your_key

# ============================================================================
# AUTOMATION OVERRIDES (Optional - customize for your needs)
# ============================================================================

# Auto-save quiz results every 30 seconds
# VITE_AUTO_SAVE_INTERVAL=30000

# Auto-generate quiz reports
# VITE_AUTO_REPORT_GENERATION=true

# Email results after quiz (requires EmailJS setup)
# VITE_EMAIL_ON_QUIZ_COMPLETE=true

# Auto-backup data daily
# VITE_AUTO_BACKUP_ENABLED=true
# VITE_AUTO_BACKUP_INTERVAL=86400000

# Cleanup old data after 90 days
# VITE_AUTO_CLEANUP_ENABLED=true
# VITE_AUTO_CLEANUP_DAYS=90

# ============================================================================
# DEVELOPMENT OVERRIDES
# ============================================================================

# Show debug info in console
# VITE_DEBUG_MODE=true

# Use mock API responses for testing
# VITE_MOCK_API_RESPONSES=true

# Enable performance monitoring
# VITE_PERFORMANCE_MONITORING=true

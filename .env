# ============================================================================
# PrepPro Environment Configuration
# Production-Grade Configuration with Automation
# Generated for 40+ years developer experience
# ============================================================================

# ============================================================================
# APPLICATION CORE
# ============================================================================
VITE_APP_NAME=PrepPro
VITE_APP_ENV=development
VITE_APP_VERSION=1.0.0
VITE_APP_DESCRIPTION=AI-Powered Interview Preparation Platform
VITE_DEBUG_MODE=false

# ============================================================================
# AI & LANGUAGE MODELS (FREE TIER SERVICES)
# ============================================================================

# Google Gemini API (FREE - 60 requests per minute)
# Get key from: https://makersuite.google.com/app/apikey
VITE_GEMINI_API_KEY=AIzaSyBkVfKuiVRW6ZjQest2CgZwB1IQA2GnztA
VITE_GEMINI_MODEL=gemini-pro
VITE_GEMINI_MAX_TOKENS=2048
VITE_GEMINI_TEMPERATURE=0.7

# Fallback AI for Questions (Alternative - Optional)
# VITE_OPENAI_API_KEY=your_openai_key_here
# VITE_OPENAI_MODEL=gpt-3.5-turbo

# ============================================================================
# SPEECH RECOGNITION & AUDIO PROCESSING (FREE TIER)
# ============================================================================

# Web Speech API (Built-in Browser - No Key Needed)
VITE_SPEECH_RECOGNITION_ENABLED=true
VITE_SPEECH_LANGUAGE=en-US
VITE_SPEECH_CONTINUOUS=true
VITE_SPEECH_INTERIM_RESULTS=true
VITE_SPEECH_MAX_ALTERNATIVES=1

# Cloudinary (FREE - 25 credits/month for video storage)
# Get key from: https://cloudinary.com/console/dashboard
VITE_CLOUDINARY_CLOUD_NAME=
VITE_CLOUDINARY_API_KEY=
VITE_CLOUDINARY_UPLOAD_PRESET=interview_video

# AssemblyAI (FREE - Limited, for transcription)
# VITE_ASSEMBLYAI_API_KEY=

# ============================================================================
# DATABASE & STORAGE (LOCAL FIRST - NO COST)
# ============================================================================

# localStorage Configuration
VITE_LOCALSTORAGE_PREFIX=preppro_
VITE_LOCALSTORAGE_ENCRYPTION=true
VITE_LOCALSTORAGE_VERSION=1

# IndexedDB Configuration (Client-side DB)
VITE_INDEXEDDB_NAME=preppro_db
VITE_INDEXEDDB_VERSION=1
VITE_INDEXEDDB_STORE_NAME=data_store

# Optional: Firebase Realtime DB (FREE tier 100 connections)
# VITE_FIREBASE_API_KEY=
# VITE_FIREBASE_PROJECT_ID=
# VITE_FIREBASE_DATABASE_URL=

# Optional: Supabase (PostgreSQL - FREE tier)
# VITE_SUPABASE_URL=
# VITE_SUPABASE_ANON_KEY=

# ============================================================================
# AUTO-SAVE & DATA PERSISTENCE AUTOMATION
# ============================================================================

# Auto-save intervals (milliseconds)
VITE_AUTO_SAVE_INTERVAL=30000
VITE_AUTO_SAVE_QUIZ_RESULTS=true
VITE_AUTO_SAVE_INTERVIEW_RECORDING=true
VITE_AUTO_SAVE_PERFORMANCE_METRICS=true
VITE_AUTO_SAVE_RESUME_DATA=true

# Data backup automation
VITE_AUTO_BACKUP_ENABLED=true
VITE_AUTO_BACKUP_INTERVAL=604800000
VITE_AUTO_BACKUP_MAX_BACKUPS=5
VITE_AUTO_BACKUP_COMPRESSION=true

# Auto-cleanup old data
VITE_AUTO_CLEANUP_ENABLED=true
VITE_AUTO_CLEANUP_DAYS=90
VITE_AUTO_CLEANUP_INTERVAL=2592000000

# ============================================================================
# REPORT GENERATION & EXPORT AUTOMATION
# ============================================================================

# Auto-generate reports
VITE_AUTO_REPORT_GENERATION=true
VITE_REPORT_FORMAT=pdf,json,csv
VITE_REPORT_INCLUDE_CHARTS=true
VITE_REPORT_INCLUDE_RECOMMENDATIONS=true

# Export options
VITE_EXPORT_ENABLED=true
VITE_EXPORT_FORMATS=pdf,csv,json,docx
VITE_EXPORT_INCLUDE_METADATA=true
VITE_EXPORT_INCLUDE_EXPLANATIONS=true

# PDF Generation (jsPDF library - built-in)
VITE_PDF_PAGE_SIZE=A4
VITE_PDF_ORIENTATION=portrait
VITE_PDF_COMPRESSION=true

# ============================================================================
# EMAIL AUTOMATION (FREE SERVICES)
# ============================================================================

# Email notifications for results (Optional)
VITE_EMAIL_AUTOMATION_ENABLED=false

# EmailJS (FREE - 200 emails/month)
# Get free account: https://www.emailjs.com
VITE_EMAILJS_SERVICE_ID=
VITE_EMAILJS_TEMPLATE_ID=
VITE_EMAILJS_PUBLIC_KEY=

# Resend (FREE - 100 emails/day in development)
# VITE_RESEND_API_KEY=

# Email notifications to send
VITE_EMAIL_ON_QUIZ_COMPLETE=false
VITE_EMAIL_ON_INTERVIEW_COMPLETE=false
VITE_EMAIL_ON_WEEKLY_REPORT=false
VITE_EMAIL_RECIPIENT_ADDRESS=user@example.com

# ============================================================================
# CACHING & PERFORMANCE OPTIMIZATION
# ============================================================================

# Browser Cache Settings
VITE_CACHE_ENABLED=true
VITE_CACHE_STRATEGY=stale-while-revalidate
VITE_CACHE_MAX_AGE=604800000
VITE_CACHE_VERSIONING=true

# Service Worker
VITE_SERVICE_WORKER_ENABLED=true
VITE_SERVICE_WORKER_SCOPE=/
VITE_OFFLINE_MODE_ENABLED=true

# Image Optimization
VITE_IMAGE_OPTIMIZATION_ENABLED=true
VITE_IMAGE_LAZY_LOADING=true
VITE_IMAGE_MAX_WIDTH=1920
VITE_IMAGE_QUALITY=0.8

# ============================================================================
# RATE LIMITING & AUTOMATION THROTTLING
# ============================================================================

# API Rate Limiting
VITE_API_RATE_LIMIT_REQUESTS=100
VITE_API_RATE_LIMIT_WINDOW=60000
VITE_API_RATE_LIMIT_RETRY_ATTEMPTS=3
VITE_API_RATE_LIMIT_RETRY_DELAY=1000

# Gemini API Rate Limiting (60 req/min free tier)
VITE_GEMINI_RATE_LIMIT=60
VITE_GEMINI_RATE_LIMIT_WINDOW=60000
VITE_GEMINI_QUEUE_ENABLED=true
VITE_GEMINI_QUEUE_MAX_SIZE=50

# Auto-retry configuration
VITE_AUTO_RETRY_ENABLED=true
VITE_AUTO_RETRY_ATTEMPTS=3
VITE_AUTO_RETRY_DELAY=1000
VITE_AUTO_RETRY_BACKOFF_MULTIPLIER=2

# ============================================================================
# LOGGING & DEBUGGING
# ============================================================================

# Logging Configuration
VITE_LOG_LEVEL=info
VITE_LOG_FORMAT=json
VITE_LOG_TO_CONSOLE=true
VITE_LOG_TO_STORAGE=true
VITE_LOG_MAX_STORAGE_SIZE=5242880

# Error Tracking
VITE_ERROR_REPORTING_ENABLED=true
VITE_ERROR_TRACKING_SERVICE=console
VITE_ERROR_INCLUDE_STACKTRACE=true
VITE_ERROR_SANITIZE_SENSITIVE_DATA=true

# Performance Monitoring
VITE_PERFORMANCE_MONITORING=true
VITE_PERFORMANCE_LOG_THRESHOLD=1000
VITE_PERFORMANCE_INCLUDE_METRICS=true

# ============================================================================
# ANALYTICS & DATA COLLECTION (PRIVACY-FIRST)
# ============================================================================

# Analytics (Privacy-focused - no personal data)
VITE_ANALYTICS_ENABLED=true
VITE_ANALYTICS_SERVICE=local
VITE_ANALYTICS_TRACK_QUIZ_RESULTS=true
VITE_ANALYTICS_TRACK_INTERVIEW_PRACTICE=true
VITE_ANALYTICS_TRACK_PERFORMANCE=true
VITE_ANALYTICS_ANONYMIZE_DATA=true

# Optional: Plausible Analytics (FREE/Paid - Privacy-first)
# Get key from: https://plausible.io
VITE_PLAUSIBLE_DOMAIN=
VITE_PLAUSIBLE_API_KEY=

# Optional: Fathom Analytics (Privacy-first)
# VITE_FATHOM_SITE_ID=

# ============================================================================
# FEATURE FLAGS & EXPERIMENTATION
# ============================================================================

# Feature Flags for gradual rollout
VITE_FEATURE_FLAG_NEW_QUIZ_ENGINE=true
VITE_FEATURE_FLAG_VOICE_ANALYSIS=true
VITE_FEATURE_FLAG_VIDEO_RECORDING=true
VITE_FEATURE_FLAG_AI_RECOMMENDATIONS=true
VITE_FEATURE_FLAG_EXPORT_REPORTS=true
VITE_FEATURE_FLAG_EMAIL_NOTIFICATIONS=false
VITE_FEATURE_FLAG_CLOUD_SYNC=false

# Beta Features (Testing)
VITE_BETA_FEATURES_ENABLED=false
VITE_BETA_ADMIN_PASSWORD=changeme

# ============================================================================
# QUIZ & INTERVIEW SETTINGS AUTOMATION
# ============================================================================

# Auto-generate questions
VITE_AUTO_GENERATE_QUESTIONS=true
VITE_QUESTIONS_PER_SESSION=20
VITE_DIFFICULTY_LEVEL=mixed
VITE_QUESTIONS_CACHE_DURATION=2592000000

# Interview Settings
VITE_INTERVIEW_TIME_LIMIT=600
VITE_INTERVIEW_AUTO_SAVE_INTERVAL=10000
VITE_INTERVIEW_AUTO_PAUSE_ON_SILENCE=false
VITE_INTERVIEW_PAUSE_DURATION=5000
VITE_INTERVIEW_VIDEO_QUALITY=720p

# Voice Analysis Automation
VITE_VOICE_ANALYSIS_ENABLED=true
VITE_VOICE_ANALYSIS_REAL_TIME=true
VITE_VOICE_ANALYSIS_DETECT_FILLER_WORDS=true
VITE_VOICE_ANALYSIS_DETECT_PACE=true
VITE_VOICE_ANALYSIS_DETECT_CONFIDENCE=true
VITE_VOICE_ANALYSIS_DETECT_PRONUNCIATION=true

# ============================================================================
# RESUME PARSING & JOB MATCHING AUTOMATION
# ============================================================================

# Resume Analysis
VITE_RESUME_AUTO_PARSE=true
VITE_RESUME_EXTRACT_SKILLS=true
VITE_RESUME_EXTRACT_EXPERIENCE=true
VITE_RESUME_EXTRACT_EDUCATION=true
VITE_RESUME_AUTO_MATCH_JOBS=true

# Job Matching (Auto-suggest roles)
VITE_AUTO_JOB_ROLE_SUGGESTION=true
VITE_JOB_ROLE_MATCH_THRESHOLD=70

# Free Resume Parser APIs (Optional)
# pdfparse.com API (FREE)
VITE_RESUME_PARSER_API=

# ============================================================================
# NOTIFICATION & ALERT AUTOMATION
# ============================================================================

# Browser Notifications
VITE_BROWSER_NOTIFICATIONS_ENABLED=true
VITE_NOTIFICATION_ON_QUIZ_COMPLETE=true
VITE_NOTIFICATION_ON_INTERVIEW_COMPLETE=true
VITE_NOTIFICATION_ON_ACHIEVEMENT=true
VITE_NOTIFICATION_SOUND_ENABLED=true

# Reminder Notifications (Auto-prompt practice)
VITE_AUTO_REMINDER_ENABLED=false
VITE_AUTO_REMINDER_INTERVAL=604800000
VITE_AUTO_REMINDER_TIME=09:00
VITE_AUTO_REMINDER_MESSAGE=Time for your daily practice!

# ============================================================================
# SECURITY & AUTHENTICATION
# ============================================================================

# Security Headers
VITE_SECURITY_HEADERS_ENABLED=true
VITE_CORS_ENABLED=true
VITE_CORS_ORIGIN=http://localhost:8080

# Data Encryption (Client-side)
VITE_ENCRYPTION_ENABLED=true
VITE_ENCRYPTION_ALGORITHM=AES-256-GCM
VITE_ENCRYPTION_KEY_DERIVATION=PBKDF2

# Session Management
VITE_SESSION_TIMEOUT=1800000
VITE_SESSION_WARNING_TIME=300000
VITE_AUTO_LOGOUT=true
VITE_REMEMBER_ME_ENABLED=true
VITE_REMEMBER_ME_DURATION=2592000000

# Password-less Authentication (Future)
VITE_PASSWORDLESS_AUTH_ENABLED=false
VITE_AUTH_METHOD=local

# ============================================================================
# PERFORMANCE TUNING & OPTIMIZATION
# ============================================================================

# Code Splitting
VITE_CODE_SPLITTING_ENABLED=true
VITE_LAZY_LOAD_ROUTES=true
VITE_LAZY_LOAD_COMPONENTS=true

# Bundle Optimization
VITE_BUNDLE_ANALYSIS_ENABLED=false
VITE_MINIFY_ENABLED=true
VITE_GZIP_COMPRESSION=true

# Resource Prefetching
VITE_RESOURCE_PREFETCH_ENABLED=true
VITE_DNS_PREFETCH_ENABLED=true
VITE_PRECONNECT_ENABLED=true

# ============================================================================
# WEBHOOKS & INTEGRATIONS (Future)
# ============================================================================

# Webhook URLs for integrations
VITE_WEBHOOK_ON_QUIZ_COMPLETE=
VITE_WEBHOOK_ON_INTERVIEW_COMPLETE=

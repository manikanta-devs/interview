VITE_TEST_MODE=false
VITE_MOCK_API_RESPONSES=false
VITE_MOCK_VOICE_INPUT=false
VITE_MOCK_VIDEO_INPUT=false

# Development Tools
VITE_DEVTOOLS_ENABLED=true
VITE_REACT_DEVTOOLS=true
